name: REPLACE_WITH_PROJECT_SLUG-webapp
region: REPLACE_WITH_DO_APP_REGION
alerts:
  - rule: DEPLOYMENT_FAILED
  - rule: DOMAIN_FAILED
static_sites:
  - name: webapp
    github:
      repo: REPLACE_WITH_GITHUB_REPO
      branch: REPLACE_WITH_GIT_BRANCH
      deploy_on_push: true
    source_dir: /
    environment_slug: node-js
    build_command: bun install --frozen-lockfile && bun run build:webapp
    output_dir: webapp/dist
    index_document: index.html
    catchall_document: index.html
    envs:
      - key: VITE_API_URL
        value: "https://REPLACE_WITH_BACKEND_DEFAULT_INGRESS"
        scope: BUILD_TIME
        type: GENERAL
